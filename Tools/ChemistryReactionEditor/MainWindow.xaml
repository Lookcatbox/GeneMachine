<Window x:Class="ChemistryReactionEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ChemistryReactionEditor"
        Title="化学反应编辑器" Height="820" Width="1280"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:HexToBrushConverter x:Key="HexToBrushConverter" />
    </Window.Resources>
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="打开" Width="80" Margin="0,0,6,0" Click="Open_Click" />
            <Button Content="保存" Width="80" Margin="0,0,6,0" Click="Save_Click" />
            <Button Content="另存为" Width="80" Margin="0,0,6,0" Click="SaveAs_Click" />
            <Button Content="验证" Width="80" Margin="0,0,12,0" Click="Validate_Click" />
            <TextBlock Text="{Binding CurrentPath}" VerticalAlignment="Center" Foreground="#555" />
        </StackPanel>

        <TextBox DockPanel.Dock="Bottom" Height="90" Margin="0,8,0,0"
                 Text="{Binding StatusText}" TextWrapping="Wrap"
                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.0*" />
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="2.4*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="物质" Margin="0,0,8,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4">
                        <Button Content="新增物质" Width="90" Margin="0,0,6,0" Click="AddSubstance_Click" />
                        <Button Content="删除物质" Width="90" Click="DeleteSubstance_Click" />
                    </StackPanel>
                    <DataGrid x:Name="SubstanceGrid"
                              ItemsSource="{Binding Config.Substances}"
                              SelectedItem="{Binding SelectedSubstance}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Margin="4">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="id" Binding="{Binding Id, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                            <DataGridTextColumn Header="显示名" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                            <DataGridTextColumn Header="形态" Binding="{Binding Phase, UpdateSourceTrigger=PropertyChanged}" Width="75" />
                            <DataGridTemplateColumn Header="颜色" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="4,2"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="SubstanceColor_Click"
                                                ToolTip="点击编辑颜色">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="18"
                                                        Height="18"
                                                        Margin="0,0,6,0"
                                                        BorderBrush="#AAA"
                                                        BorderThickness="1"
                                                        CornerRadius="2"
                                                        Background="{Binding Color, Converter={StaticResource HexToBrushConverter}}" />
                                                <TextBlock Text="{Binding Color}"
                                                           VerticalAlignment="Center"
                                                           FontFamily="Consolas"
                                                           FontSize="12" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="热力图上限" Binding="{Binding OverlayMax, UpdateSourceTrigger=PropertyChanged}" Width="85" />
                            <DataGridTextColumn Header="陆地基准" Binding="{Binding BaselineLand, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                            <DataGridTextColumn Header="水域基准" Binding="{Binding BaselineWater, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="反应（拖动排序决定优先级）" Margin="0,0,8,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4">
                        <Button Content="新增反应" Width="90" Margin="0,0,6,0" Click="AddReaction_Click" />
                        <Button Content="删除反应" Width="90" Click="DeleteReaction_Click" />
                    </StackPanel>
                    <ListBox x:Name="ReactionList"
                             ItemsSource="{Binding Config.Reactions}"
                             SelectedItem="{Binding SelectedReaction}"
                             DisplayMemberPath="Title"
                             AllowDrop="True"
                             PreviewMouseMove="ReactionList_PreviewMouseMove"
                             Drop="ReactionList_Drop"
                             Margin="4" />
                </DockPanel>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="反应详情">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8" DataContext="{Binding SelectedReaction}">
                        <TextBlock Text="基础信息" FontWeight="Bold" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="id" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}" TextChanged="ReactionName_TextChanged" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="名称" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" TextChanged="ReactionName_TextChanged" Margin="0,0,0,4" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="启用" VerticalAlignment="Center" />
                            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding Enabled}" Margin="0,0,0,8" />
                        </Grid>

                        <TextBlock Text="反应物" FontWeight="Bold" Margin="0,8,0,4" />
                        <DataGrid ItemsSource="{Binding Reactants}" AutoGenerateColumns="False" CanUserAddRows="True" Height="130">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="物质 id" Binding="{Binding SubstanceId, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTextColumn Header="系数" Binding="{Binding Coeff, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="生成物" FontWeight="Bold" Margin="0,8,0,4" />
                        <DataGrid ItemsSource="{Binding Products}" AutoGenerateColumns="False" CanUserAddRows="True" Height="130">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="物质 id" Binding="{Binding SubstanceId, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                <DataGridTextColumn Header="系数" Binding="{Binding Coeff, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="条件表达式" FontWeight="Bold" Margin="0,8,0,4" />
                        <TextBox Text="{Binding Condition, UpdateSourceTrigger=PropertyChanged}" Height="70" AcceptsReturn="True" TextWrapping="Wrap" />

                        <TextBlock Text="动力方程表达式" FontWeight="Bold" Margin="0,8,0,4" />
                        <TextBox Text="{Binding RateExpression, UpdateSourceTrigger=PropertyChanged}" Height="70" AcceptsReturn="True" TextWrapping="Wrap" />

                        <TextBlock Margin="0,8,0,0" Foreground="#666"
                                   Text="可用变量：tempC、light、height、topography、limiting、amount[&quot;id&quot;]、reactantCoeff[&quot;id&quot;]、productCoeff[&quot;id&quot;]。函数：min/max/clamp/pow/abs。" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
